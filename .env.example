# Google Gemini API Key
# Get it from: https://aistudio.google.com/
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face API Token
# Get it from: https://huggingface.co/settings/tokens
EXPO_PUBLIC_HF_TOKEN=your_huggingface_token_here

# Cloudflare Credentials
# Account ID can be found in your Cloudflare dashboard URL
EXPO_PUBLIC_CF_ACCOUNT_ID=your_cloudflare_account_id_here
# API Token with Workers AI permissions
EXPO_PUBLIC_CF_API_TOKEN=your_cloudflare_api_token_here
